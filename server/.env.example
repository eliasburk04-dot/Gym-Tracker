# Server
PORT=3000
HOST=0.0.0.0

# Database
DATABASE_URL=postgresql://taplift:taplift_secret@localhost:5432/taplift

# Firebase Admin SDK - path to service account JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# CORS (comma-separated origins; leave empty for no browser CORS)
CORS_ORIGIN=

# Auth bootstrap safety (recommended true in production)
REQUIRE_FIREBASE_AUTH=true
