generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id
  email        String?  @unique
  displayName  String?
  authProvider String   // 'apple', 'google', 'email'
  weightUnit   String   @default("kg")
  weightIncrement Float @default(2.5)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workoutDays  WorkoutDay[]
  weekdayPlans WeekdayPlan[]
  workoutSets  WorkoutSet[]
}

model WorkoutDay {
  id        String   @id @default(uuid())
  userId    String
  name      String
  sortIndex Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises    Exercise[]
  weekdayPlans WeekdayPlan[]

  @@index([userId])
}

model WeekdayPlan {
  id           String  @id @default(uuid())
  userId       String
  weekday      Int     // 1=Monday .. 7=Sunday
  workoutDayId String? // null = Rest day

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  workoutDay WorkoutDay? @relation(fields: [workoutDayId], references: [id], onDelete: SetNull)

  @@unique([userId, weekday])
  @@index([userId])
}

model Exercise {
  id                 String @id @default(uuid())
  workoutDayId       String
  name               String
  sortIndex          Int    @default(0)
  lastSelectedReps   Int    @default(8)
  lastSelectedWeight Float  @default(20.0)
  targetSets         Int    @default(3)
  targetWeight       Float  @default(0.0)
  repTargetMin       Int    @default(8)
  repTargetMax       Int    @default(12)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workoutDay  WorkoutDay   @relation(fields: [workoutDayId], references: [id], onDelete: Cascade)
  workoutSets WorkoutSet[]

  @@index([workoutDayId])
}

model WorkoutSet {
  id         String   @id @default(uuid())
  exerciseId String
  userId     String
  setNumber  Int      @default(1)
  reps       Int
  weight     Float
  rir        Int?     // Reps in Reserve (null = not tracked)
  source     String   @default("app") // 'app' | 'liveActivity'
  timestamp  DateTime @default(now())

  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([exerciseId])
  @@index([userId])
  @@index([userId, timestamp])
}
